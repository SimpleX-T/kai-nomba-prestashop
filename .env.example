# Nomba sandbox credentials — copy to .env and fill from the Nomba dashboard:
# Settings -> Webhooks & API Keys -> TEST keys.
# .env is gitignored. NEVER commit real keys.

NOMBA_TEST_MODE=true
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=
NOMBA_SIGNATURE_KEY=

# Public tunnel URL (cloudflared/ngrok) used as the webhook target during testing.
# e.g. https://your-tunnel.trycloudflare.com/module/nomba/webhook
NOMBA_WEBHOOK_URL=
